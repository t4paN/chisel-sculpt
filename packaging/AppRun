#!/usr/bin/env bash
APPDIR="$(dirname "$(readlink -f "$0")")"
ICON_SRC="$APPDIR/chisel.png"
DESKTOP_SRC="$APPDIR/chisel.desktop"
ICON_DEST="$HOME/.local/share/icons/hicolor/256x256/apps/chisel.png"
DESKTOP_DEST="$HOME/.local/share/applications/chisel.desktop"

# Install (or refresh) the menu entry + icon, pointing Exec at the real .AppImage
# path. Idempotent; safe to call on every launch. update-desktop-database nudges
# DEs that don't watch the dir.
install_entry() {
    mkdir -p "$(dirname "$ICON_DEST")" "$(dirname "$DESKTOP_DEST")"
    cp -f "$ICON_SRC" "$ICON_DEST"
    APPIMAGE_PATH="$(readlink -f "${APPIMAGE:-$0}")"
    sed "s|^Exec=.*|Exec=\"$APPIMAGE_PATH\"|" "$DESKTOP_SRC" > "$DESKTOP_DEST"
    command -v update-desktop-database >/dev/null 2>&1 \
        && update-desktop-database "$(dirname "$DESKTOP_DEST")" >/dev/null 2>&1 || true
    # Refresh the icon cache so DEs (XFCE) ingest the freshly-copied icon —
    # update-desktop-database only reindexes .desktop files, not icons. The
    # user-local hicolor tree has no index.theme, so -t/--ignore-theme-index.
    command -v gtk-update-icon-cache >/dev/null 2>&1 \
        && gtk-update-icon-cache -f -t "$HOME/.local/share/icons/hicolor" >/dev/null 2>&1 || true
    command -v xdg-icon-resource >/dev/null 2>&1 \
        && xdg-icon-resource forceupdate --theme hicolor >/dev/null 2>&1 || true
}

case "${1:-}" in
    --install)
        install_entry
        echo "Chisel installed to desktop. Icon and launcher added."
        echo "  Desktop: $DESKTOP_DEST"
        echo "  Icon:    $ICON_DEST"
        exit 0
        ;;
    --uninstall)
        rm -f "$ICON_DEST" "$DESKTOP_DEST"
        command -v update-desktop-database >/dev/null 2>&1 \
            && update-desktop-database "$(dirname "$DESKTOP_DEST")" >/dev/null 2>&1 || true
        echo "Chisel desktop entry and icon removed."
        exit 0
        ;;
esac

# Auto-register on a normal launch so the app appears in the start menu without
# an explicit --install. Guarded on $APPIMAGE so running the raw AppDir during
# dev (no .AppImage path) doesn't write a stale Exec pointing inside the AppDir.
if [ -n "${APPIMAGE:-}" ]; then
    install_entry
fi

# Prefer libs bundled into the AppImage (CI bundles into usr/lib; a local build
# may not, in which case this dir simply doesn't exist and is a harmless no-op).
export LD_LIBRARY_PATH="$APPDIR/usr/lib:${LD_LIBRARY_PATH}"
exec "$APPDIR/usr/bin/chisel" "$@"
